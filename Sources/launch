#!/bin/bash
# ============================================================
#  合盖不休眠 v15.2 — 快速响应 + 菜单栏版
#
#  v15.2 改进：
#    - 添加系统版本检查（最低 macOS 11.0）
#    - 添加 Swift 运行时检查
#    - menulet 启动失败时弹出错误提示
#    - 启动后验证菜单栏图标是否出现
#    - 详细的排错日志
#
#  启动流程：
#    launch → 系统检查 → 首次免密配置 → 启动 menulet → 验证
# ============================================================

LOG_FILE="/tmp/nosleep_debug.log"
SUDOERS_FILE="/etc/sudoers.d/nosleep"
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
MENULET="$SCRIPT_DIR/menulet"
BACKLIGHTCTL="$SCRIPT_DIR/backlightctl"

# ---- 日志函数 ----
log() {
    echo "[$(date '+%H:%M:%S')] $*" >> "$LOG_FILE"
}

# ---- 错误弹窗 ----
show_error() {
    /usr/bin/osascript -e "display dialog \"$1\" buttons {\"好的\"} with title \"合盖不休眠\" with icon stop" 2>/dev/null
}

# ---- 通知 ----
show_notify() {
    /usr/bin/osascript -e "display notification \"$1\" with title \"合盖不休眠\"" 2>/dev/null
}

log "=== APP 启动 ==="

# ---- 1. 系统版本检查 ----
log "检查系统版本..."
MACOS_VERSION=$(sw_vers -productVersion 2>/dev/null)
log "macOS 版本: $MACOS_VERSION"

# 提取主版本号 (如 11.0, 14.5)
MAJOR=$(echo "$MACOS_VERSION" | cut -d. -f1)
if [ -z "$MAJOR" ] || [ "$MAJOR" -lt 11 ] 2>/dev/null; then
    log "❌ 系统版本过低: $MACOS_VERSION"
    show_error "系统版本过低！\n\n当前: macOS $MACOS_VERSION\n需要: macOS 11.0 (Big Sur) 或更高版本\n\n请在「关于本机」中检查系统版本。"
    exit 1
fi
log "✅ 系统版本符合要求"

# ---- 2. 检查 menulet ----
log "检查 menulet..."
if [ ! -f "$MENULET" ]; then
    log "❌ menulet 不存在: $MENULET"
    show_error "缺少 menulet 组件！\n\nApp 可能已损坏，请重新下载安装。"
    exit 1
fi

if [ ! -x "$MENULET" ]; then
    log "⚠️ menulet 不可执行，尝试修复权限..."
    chmod +x "$MENULET" 2>/dev/null
    if [ ! -x "$MENULET" ]; then
        log "❌ 无法修复 menulet 权限"
        show_error "menulet 权限异常！\n\n请在终端执行：\nchmod +x \"$MENULET\""
        exit 1
    fi
fi
log "✅ menulet 就绪"

# ---- 3. 检查 backlightctl ----
log "检查 backlightctl..."
if [ ! -f "$BACKLIGHTCTL" ]; then
    log "❌ backlightctl 不存在: $BACKLIGHTCTL"
    show_error "缺少 backlightctl 工具！\n\nApp 可能已损坏，请重新下载安装。"
    exit 1
fi

if [ ! -x "$BACKLIGHTCTL" ]; then
    log "⚠️ backlightctl 不可执行，尝试修复权限..."
    chmod +x "$BACKLIGHTCTL" 2>/dev/null
fi
log "✅ backlightctl 就绪"

# ---- 4. 检查 Python3 ----
log "检查 Python3..."
if [ ! -x "/usr/bin/python3" ]; then
    log "❌ /usr/bin/python3 不存在"
    show_error "缺少 Python 3！\n\nmacOS 11.0+ 应自带 Python 3。\n如果没有，请在终端执行：\nxcode-select --install"
    exit 1
fi
log "✅ Python3 就绪"

# ---- 5. 免密检查 ----
has_nopasswd() {
    /usr/bin/sudo -n /usr/bin/pmset -g > /dev/null 2>&1
}

# ---- 首次配置免密 ----
setup_nopasswd() {
    /usr/bin/osascript <<'EOF'
set pw to text returned of (display dialog ¬
    "首次使用「合盖不休眠」\n\n需要配置一次管理员授权。\n配置完成后，以后切换开关不再需要输入密码。\n\n请输入电脑登录密码：" ¬
    default answer "" ¬
    with title "首次设置" ¬
    with hidden answer ¬
    buttons {"取消", "确定"} ¬
    default button "确定")

if pw is not "" then
    do shell script "echo " & quoted form of pw & " | sudo -S bash -c 'echo \"ALL ALL=NOPASSWD: /usr/bin/pmset\" > /etc/sudoers.d/nosleep && chmod 444 /etc/sudoers.d/nosleep' 2>&1"

    set check to do shell script "sudo -n pmset -g > /dev/null 2>&1 && echo OK || echo FAIL"
    if check is "OK" then
        display notification "免密配置成功 ✓" with title "合盖不休眠"
        return "ok"
    else
        display dialog "配置失败，请重试" buttons {"好的"}
        return "fail"
    end if
else
    return "cancel"
end if
EOF
}

# ---- 配置免密 ----
log "检查免密状态..."

if ! has_nopasswd; then
    log "未配置免密，弹出设置窗口"
    SETUP_RESULT=$(setup_nopasswd)
    if ! has_nopasswd; then
        log "免密配置失败，退出"
        show_error "免密配置失败！\n\n可能原因：\n1. 密码输入错误\n2. 当前用户不是管理员\n\n请在终端手动执行：\nsudo echo 'ALL ALL=NOPASSWD: /usr/bin/pmset' > /etc/sudoers.d/nosleep"
        exit 1
    fi
fi
log "✅ 免密已配置"

# ---- 6. 检查并修复孤儿状态 ----
if [ -f "/tmp/no-sleep-lidwatch.pid" ]; then
    pid=$(cat "/tmp/no-sleep-lidwatch.pid")
    if ! kill -0 "$pid" 2>/dev/null; then
        disabled=$(/usr/bin/pmset -g 2>/dev/null | grep 'SleepDisabled' | awk '{print $2}')
        if [ "$disabled" = "1" ]; then
            log "⚠️ 孤儿状态：功能开启但 lidwatch 已死，menulet 会处理"
        fi
    fi
fi

# ---- 7. 检查是否已经在运行 ----
if pgrep -f "合盖不休眠.app/Contents/MacOS/menulet" > /dev/null 2>&1; then
    log "menulet 已在运行，不重复启动"
    show_notify "已在菜单栏运行中"
    exit 0
fi

# ---- 8. 启动 menulet ----
log "启动 menulet（菜单栏常驻进程）"
"$MENULET" &
MENULET_PID=$!
log "menulet 已启动，PID: $MENULET_PID"

# ---- 9. 验证 menulet 是否成功启动 ----
sleep 2

if kill -0 "$MENULET_PID" 2>/dev/null; then
    log "✅ menulet 运行正常"
    show_notify "已启动，点菜单栏🌙图标操作"
else
    log "❌ menulet 启动后崩溃了！"
    
    # 检查崩溃原因
    CRASH_LOG=$(ls -t ~/Library/Logs/DiagnosticReports/menulet* 2>/dev/null | head -1)
    
    ERROR_MSG="menulet 启动失败！\n\n可能原因：\n1. macOS 版本与 Swift 运行时不兼容\n2. 系统权限限制\n\n排错方法：\n在终端执行以下命令查看错误：\n\"$MENULET\""
    
    if [ -n "$CRASH_LOG" ]; then
        log "崩溃日志: $CRASH_LOG"
        ERROR_MSG="$ERROR_MSG\n\n崩溃日志：$CRASH_LOG"
    fi
    
    show_error "$ERROR_MSG"
    exit 1
fi

log "=== launch 退出（menulet 后台运行中）==="
